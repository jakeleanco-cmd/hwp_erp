{
  "name": "hwp_erp",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently \"npm run vite:dev\" \"npm run electron:dev\" \"npm run server:dev\"",
    "web": "concurrently \"npm run vite:dev\" \"npm run server:dev\"",
    "kill-port": "npx kill-port 3001",
    "preweb": "npm run kill-port",
    "vite:dev": "vite",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "server:dev": "npm --prefix server run dev",
    "build": "vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@google/generative-ai": "^0.24.1",
    "antd": "^6.3.6",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.11.0",
    "mongoose": "^9.5.0",
    "multer": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-katex": "^3.1.0",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
